# Anthropic (server-only)
ANTHROPIC_API_KEY=

# Supabase (public — safe in browser)
NEXT_PUBLIC_SUPABASE_URL=
# Как в novoprint-accounting: можно вместо anon указать publishable key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: only if you add server-side admin scripts (not required for this app’s API routes)
# SUPABASE_SERVICE_ROLE_KEY=

# Для команды миграций к облаку (scripts/push-remote.ps1): URI из Dashboard → Database → Connection string
# DATABASE_URL=postgresql://postgres:ПАРОЛЬ@db.xxxxx.supabase.co:5432/postgres
