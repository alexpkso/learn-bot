# Anthropic (server-only)
ANTHROPIC_API_KEY=

# Supabase — для браузера (обязательно префикс NEXT_PUBLIC_):
NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Либо только серверные имена (без NEXT_PUBLIC_) — подхватятся в runtime на сервере и через корневой layout:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Optional: only if you add server-side admin scripts (not required for this app’s API routes)
# SUPABASE_SERVICE_ROLE_KEY=

# Для команды миграций к облаку (scripts/push-remote.ps1): URI из Dashboard → Database → Connection string
# DATABASE_URL=postgresql://postgres:ПАРОЛЬ@db.xxxxx.supabase.co:5432/postgres
